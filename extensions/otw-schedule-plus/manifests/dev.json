{
  "manifest_version": 3,
  "name": "OTW Schedule + Dev",
  "description": "오버더월 스케줄표의 멀티뷰 기능을 보조하고 향후 방송 알림 등 편의 기능을 제공할 전용 확장입니다.",
  "version": "0.2.11",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "OTW Schedule +"
  },
  "permissions": ["storage", "scripting"],
  "optional_permissions": ["cookies"],
  "host_permissions": [
    "https://chzzk.naver.com/*",
    "https://otw-schedule.info/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": ["https://nid.naver.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chzzk.naver.com/*"],
      "js": ["chzzk-content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://otw-schedule.info/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["otw-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
